# ==============================================================================
# Confia — variables d'environnement (développement local)
# ==============================================================================
# Copier ce fichier en .env.local puis renseigner les valeurs réelles.
# .env.local n'est jamais versionné (voir .gitignore).

# --- Supabase (local via `npx supabase start`, ou projet cloud) ------------
# Valeurs par défaut de la stack locale — à remplacer par les vraies clés du
# projet Supabase une fois celui-ci créé (cf. `npx supabase status`).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Genius Pay (agrégateur de paiement : dépôts & retraits) ---------------
# Clés disponibles sur https://geniuspay.ci (Paramètres → API).
# Utiliser les clés "sandbox" (pk_sandbox_.../sk_sandbox_...) tant que les
# tests ne sont pas terminés ; les clés "live" ne doivent jamais être commitées.
GENIUS_PAY_API_BASE_URL=https://geniuspay.ci/api/v1/merchant
GENIUS_PAY_PUBLIC_KEY=
GENIUS_PAY_SECRET_KEY=
GENIUS_PAY_WEBHOOK_SECRET=

# --- SMTP (messagerie professionnelle LWS Panel) ----------------------------
# Deux jeux de variables distincts, car Supabase Auth (GoTrue) tourne dans un
# conteneur Docker séparé du process Next.js :
#  - SMTP_*      : utilisé par l'app Next.js elle-même (process hôte).
#  - AUTH_SMTP_* : utilisé par Supabase Auth pour ses derniers e-mails natifs
#                  (récupération de mot de passe, changement d'adresse — PAS
#                  l'inscription, qui n'utilise plus du tout Supabase Auth
#                  pour l'envoi : cf. src/lib/auth/signup-otp.ts).
# En local, ces deux jeux pointent vers le même serveur Mailpit mais via des
# adresses différentes (hôte vs réseau interne Docker) :
#   SMTP_HOST=127.0.0.1        SMTP_PORT=54325
#   AUTH_SMTP_HOST=inbucket    AUTH_SMTP_PORT=1025
# En production, les deux jeux doivent avoir les MÊMES vraies valeurs LWS
# (host public, joignable aussi bien par Vercel que par Supabase Auth).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_IGNORE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Confia
SMTP_FROM_EMAIL=

AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USER=
AUTH_SMTP_PASSWORD=

# --- Application -------------------------------------------------------------
APP_BASE_URL=http://localhost:3000

# --- Provisionnement du compte super_admin -----------------------------------
# Utilisé uniquement par POST /api/admin/bootstrap (protégé par
# ADMIN_BOOTSTRAP_SECRET) : crée ou met à jour le compte admin à partir de ces
# variables. Aucun mot de passe admin en dur nulle part — à définir seulement
# dans les variables d'environnement Vercel en production.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_BOOTSTRAP_SECRET=
